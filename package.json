{
  "type": "module",
  "packageManager": "bun@1.3.8",
  "scripts": {
    "dev": "node scripts/build-draw-search-index.mjs && node scripts/sync-recognizer-assets.mjs --copy-wasm && vite --host 127.0.0.1 --port 8000",
    "build": "node scripts/build-draw-search-index.mjs && node scripts/sync-recognizer-assets.mjs --copy-wasm && vite build --mode client && vite build",
    "benchmark:print-pdfs": "node tests/printables/run-printable-pdfs.mjs",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy",
    "measure:latency": "node scripts/measure-latency.mjs",
    "mirror:data": "node scripts/mirror-kanji-data.mjs",
    "smoke:worker": "node scripts/smoke-worker.mjs",
    "sync:draw-search-index": "node scripts/build-draw-search-index.mjs",
    "sync:recognizer": "node scripts/sync-recognizer-assets.mjs --copy-wasm",
    "sync:recognizer:r2": "node scripts/sync-recognizer-assets.mjs --upload-r2",
    "sync:recognizer:r2:staging": "node scripts/sync-recognizer-assets.mjs --upload-r2 --bucket=kanji-recognizer-assets-staging",
    "test": "vitest run",
    "test:printables": "node tests/printables/run-printable-pdfs.mjs",
    "deploy:staging": "wrangler deploy --env staging"
  },
  "dependencies": {
    "@tensorflow/tfjs-backend-cpu": "4.9.0",
    "@tensorflow/tfjs-core": "4.9.0",
    "@tensorflow/tfjs-tflite": "^0.0.1-alpha.10",
    "hono": "^4.12.14",
    "honox": "^0.1.55",
    "jspdf": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.8",
    "@cloudflare/workers-types": "^4.20260421.1",
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.25.3",
    "vite": "^7.1.12",
    "vitest": "^4.1.4",
    "wrangler": "^4.84.1"
  }
}
