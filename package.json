{
  "type": "module",
  "packageManager": "bun@1.3.8",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 8000",
    "build": "vite build --mode client && vite build",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy",
    "measure:latency": "node scripts/measure-latency.mjs",
    "mirror:data": "node scripts/mirror-kanji-data.mjs",
    "mirror:sources": "node scripts/data-pipeline/mirror-kokugo-sources.mjs",
    "graph:build": "bun scripts/data-pipeline/build-kokugo-graph.mjs",
    "graph:export": "bun scripts/data-pipeline/build-kokugo-graph.mjs",
    "graph:check": "node scripts/data-pipeline/check-kokugo-graph.mjs",
    "pipeline:refresh": "bun run mirror:sources && bun run graph:build && bun run graph:check",
    "smoke:worker": "node scripts/smoke-worker.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "hono": "^4.12.14",
    "honox": "^0.1.55"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.8",
    "@cloudflare/workers-types": "^4.20260421.1",
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.25.3",
    "vite": "^7.1.12",
    "vitest": "^4.1.4",
    "wrangler": "^4.84.1"
  }
}
